# 7) Expecting/Asserting status codes

```bash
# function that asserts expected code; returns non-zero if mismatch
expect_code() {
  local url="$1" expected="$2" opt="${3:-}"
  local code
  code="$(curl -sS $opt -o /dev/null -w '%{http_code}' "$url")" || return 2
  if [ "$code" != "$expected" ]; then
    echo "FAIL: $url expected $expected got $code" >&2
    return 1
  fi
  echo "ok: $url ($code)"
}

# Examples
expect_code "$BASE/healthz" 200
expect_code "$BASE/governance/hello" 302                   # before login
login_admin
expect_code "$BASE/governance/hello" 200 "-b $ADMIN_JAR"   # authorized
```

