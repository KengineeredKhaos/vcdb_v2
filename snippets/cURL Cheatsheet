# 5) Testing Governance policy endpoints

```bash
# Show policy page (admin)
curlh -b "$ADMIN_JAR" "$BASE/governance/policy"   # expect 200

# Snapshot JSON (admin)
curl -sS -b "$ADMIN_JAR" "$BASE/governance/policy/snapshot.json" | jq .

# Update a policy (admin): staff_spend_cap_cents=20000
set_policy() {
  local key="$1" val="$2"
  local token; token="$(get_csrf "$ADMIN_JAR")"
  curl -sS -b "$ADMIN_JAR" -c "$ADMIN_JAR" -X POST "$BASE/governance/policy/set" \
    -H 'Content-Type: application/x-www-form-urlencoded' \
    --data-urlencode "key=${key}" \
    --data-urlencode "value=${val}" \
    --data-urlencode "csrf_token=${token}" \
    -o /dev/null -w '%{http_code}\n'
}

# Refresh cache (admin)
refresh_policy_cache() {
  local token; token="$(get_csrf "$ADMIN_JAR")"
  curl -sS -b "$ADMIN_JAR" -c "$ADMIN_JAR" -X POST "$BASE/governance/policy/refresh" \
    -H 'Content-Type: application/x-www-form-urlencoded' \
    --data-urlencode "csrf_token=${token}" \
    -o /dev/null -w '%{http_code}\n'
}

# Example:
# login_admin
# set_policy staff_spend_cap_cents 20000
# refresh_policy_cache
```

