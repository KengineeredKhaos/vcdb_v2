# 2) Login flow (form + CSRF) — reusable functions

Your login form has a hidden `csrf_token`. Grab it, then POST credentials with the token. Save cookies into a jar.

```bash
# Extract a CSRF token from /auth/login
get_csrf() {
  local jar="$1"
  curl -sS -c "$jar" "$BASE/auth/login" \
  | sed -n 's/.*name="csrf_token" value="\([^"]*\)".*/\1/p'
}

# Generic login: email + password -> cookie jar
login_as() {
  local email="$1" pass="$2" jar="$3"
  local token; token="$(get_csrf "$jar")"
  curl -sS -b "$jar" -c "$jar" -X POST "$BASE/auth/login" \
    -H 'Content-Type: application/x-www-form-urlencoded' \
    --data-urlencode "email=${email}" \
    --data-urlencode "password=${pass}" \
    --data-urlencode "csrf_token=${token}" \
    -o /dev/null -w '%{http_code}\n'
}

# Convenience wrappers (adjust creds as needed)
login_user()  { login_as "user@example.com"  "password" "$USER_JAR"; }
login_admin() { login_as "admin@example.com" "password" "$ADMIN_JAR"; }

# Whoami (for sanity)
whoami_user()  { curl -sS -b "$USER_JAR"  "$BASE/auth/whoami";  echo; }
whoami_admin() { curl -sS -b "$ADMIN_JAR" "$BASE/auth/whoami"; echo; }
```

Usage:

```bash
login_user     # prints 302 on success (redirect after login)
whoami_user    # should show the user payload/session info
```

