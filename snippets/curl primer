curl primer

# Health checks
curl -i http://127.0.0.1:5001/healthz
curl -s http://127.0.0.1:5001/api/dev/health/db | jq

# JSON endpoint with query
curl -s "http://127.0.0.1:5001/api/ledger/events?limit=10" | jq

# See headers only
curl -I http://127.0.0.1:5001/

# Follow redirects (if any)
curl -IL http://127.0.0.1:5001/

# Core flags
Usage: curl [options...] <url>

 -b cookies.txt             Send cookies from jar
 -c cookies.txt             Write cookies to jar
 -d, --data <data>          HTTP POST data
 -f, --fail                 Fail fast with no output on HTTP errors
 -h, --help <category>      Get help for commands
 -i, --include              Include protocol response headers in the output
 -I, --head                 Show document info only
 -L, --location             Follow redirects
 -o, --output <file>        Write to file instead of stdout
 -O, --remote-name          Write output to a file named as the remote file
 -s, --silent               Silent mode
 -S, --show-error           Show error even when -s is used
 -sS                        silent but show errors
 -T, --upload-file <file>   Transfer local FILE to destination
 -u, --user <user:password> Server user and password
 -A, --user-agent <name>    Send User-Agent <name> to server
 -v, --verbose              Make the operation more talkative
 -V, --version              Show version number and quit
 -#, --progress-bar         Display transfer progress as a bar
 -Y, --speed-limit <speed>  Stop transfers slower than this
 -y, --speed-time <seconds> Trigger 'speed-limit' abort after this time
     --no-clobber           Do not overwrite files that already exist
     --stderr <file>        Where to redirect stderr




