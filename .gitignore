# .gitignore

# --- Dev, MVP docs, IDE environment and Tests
/MVP_docs/*
pyproject.toml
pyrightconfig.json
*.sublime-*
.cache/
*.zip

# --- Repo focus (non-app artifacts/docs)
/Canon/
/docs/
/scaffolding_docs/
/snapshots/
/snippets/
/tools/
/scripts/
/Test_rat_hole/
/lib_snapshot/

# --- Virtual Environment ---
/bin/
/include/
/lib
/lib64
/pyvenv.cfg
env/
.venv/
venv/
.pyenv/
pip-wheel-metadata/
pip-log.txt

# --- Python / build ---
__pycache__/
*.py[cod]
*.pyd
*.so
*.dll
*.dylib
*.exe
*.bin
*.egg*
.eggs/
dist/
build/
.tox/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
coverage.xml
htmlcov/
node_modules/

# --- Databases (SQLite etc.) ---
*.sqlite
*.sqlite3
*.db
*.db-*
/var
instance/*
!instance/.gitkeep

# --- Logs (DEV-ONLY JSONL, keep dirs) ---
logs/**
!logs/.gitkeep
app/logs/*.log
!app/logs/.gitkeep

# --- Runtime/output dirs (not versioned) ---
archive/**
!archive/.gitkeep
exports/**
wheelhouse/

# --- Secrets & local config ---
.env
.env.*
!.env.example
