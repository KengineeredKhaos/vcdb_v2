# ---   Virtual Environment:

From your desired root directory:

python -m venv venv

To activate from your root directory:

source bin/active

Setup:

python -V
pip --version
python -m pip install --upgrade pip wheel setuptools

Close:

deactivate

# ---  Freeze required packages list:

pip freeze --exclude-editable > requirements.txt

Quick bash script version:
#!/usr/bin/env bash
set -euo pipefail
python -m pip install --upgrade pip wheel setuptools
pip freeze --exclude-editable > requirements.txt
echo "Wrote requirements.txt"

# ---   Wheelhouse

Build local repo (wheelhouse) of binary wheels

mkdir -p wheelhouse
# Prefer prebuilt wheels; build if needed
pip download --only-binary=:all: -r requirements.txt -d wheelhouse || true
# Fallback build for any sdists that were missed above
pip wheel -r requirements.txt -w wheelhouse

Tip: Build on the same OS/arch/Python as your target.
     Wheels are platform/ABI-specific.


Install from wheelhouse

python -m venv /tmp/rehydrate
source /tmp/rehydrate/bin/activate
python -m pip install --upgrade pip
pip install --no-index --find-links=wheelhouse -r requirements.txt
