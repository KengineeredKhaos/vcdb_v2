{
  "issuance": {
    "defaults": {
      "cadence": {
        "label": "default-per-30",
        "max_per_period": 1,
        "period_days": 30,
        "scope": "classification"
      }
    },
    "rules": [
      {
        "if": {
          "source": "DR"
        },
        "then": {
          "issuance_class": "V"
        },
        "why": "All DRMO items are veteran-only"
      },
      {
        "if": {
          "category": "CG",
          "source": "LC",
          "subcategory": "SL"
        },
        "then": {
          "issuance_class": "H"
        },
        "why": "Commercial sleeping gear reserved for homeless issuance"
      }
    ]
  },
  "meta": {
    "description": "Issuance criteria and cadence rules for inventory SKUs.",
    "effective_on": "2026-02-23",
    "notes": [
      "Governance controls cadence/qualifiers/overrides only.",
      "SKU validation taxonomy belongs to Logistics slice.",
      "Issuance class 'D' means Durable (staff-issued and returned); it is not a discretionary class."
    ],
    "policy_key": "logistics_issuance",
    "schema_version": 1,
    "status": "draft",
    "title": "Logistics Issuance Policy",
    "version": 2
  },
  "sku_constraints": {
    "rules": [
      {
        "cadence": {
          "label": "bag-per-90d",
          "max_per_period": 1,
          "period_days": 90,
          "scope": "sku"
        },
        "match": {
          "sku_parts": {
            "category": "CG",
            "source": "DR",
            "subcategory": "SL"
          }
        },
        "qualifiers": {
          "homeless_required": true,
          "veteran_required": true
        }
      },
      {
        "cadence": {
          "max_per_period": 1,
          "period_days": 30,
          "scope": "classification"
        },
        "match": {
          "classification_key": "UW/TP"
        }
      },
      {
        "cadence": {
          "max_per_period": 1,
          "period_days": 90,
          "scope": "classification"
        },
        "match": {
          "classification_key": "CG/SL"
        }
      },
      {
        "match": {
          "sku_parts": {
            "issuance_class": "H"
          }
        },
        "qualifiers": {
          "homeless_required": true
        }
      },
      {
        "match": {
          "sku_parts": {
            "issuance_class": "V"
          }
        },
        "qualifiers": {
          "veteran_required": true
        }
      },
      {
        "match": {
          "sku_parts": {
            "source": "DR"
          }
        },
        "qualifiers": {
          "veteran_required": true
        }
      },
      {
        "match": {
          "sku_parts": {
            "issuance_class": "U"
          }
        }
      }
    ]
  }
}
