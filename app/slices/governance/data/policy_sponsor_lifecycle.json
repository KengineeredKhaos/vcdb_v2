{
  "version": 1,
  "readiness": {
    "default": "draft",
    "statuses": [
      { "code": "draft", "label": "Draft", "can_issue": false },
      { "code": "review", "label": "Under review", "can_issue": false },
      { "code": "active", "label": "Active", "can_issue": true },
      { "code": "suspended", "label": "Suspended", "can_issue": false }
    ]
  },
  "mou": {
    "default": "none",
    "statuses": [
      { "code": "none", "label": "No MOU", "can_issue": false },
      { "code": "pending", "label": "MOU pending", "can_issue": false },
      { "code": "active", "label": "Active MOU", "can_issue": true },
      { "code": "expired", "label": "Expired MOU", "can_issue": false },
      { "code": "terminated", "label": "Terminated", "can_issue": false }
    ]
  },
  "transitions": {
    "readiness": {
      "draft": ["review", "suspended"],
      "review": ["active", "suspended"],
      "active": ["suspended"],
      "suspended": ["review", "active"]
    },
    "mou": {
      "none": ["pending"],
      "pending": ["active", "none"],
      "active": ["expired", "terminated"],
      "expired": ["active", "terminated"]
    }
  }
}
