{
  "meta": {
    "description": "Funding decision preview rules for eligibility, preference ordering, and approvals.",
    "effective_on": "2026-03-13",
    "notes": [
      "Used by Calendar publish flow and Finance reserve/encumber preview flow.",
      "Rules operate on semantic keys only."
    ],
    "policy_key": "funding_decisions",
    "schema_version": 1,
    "status": "draft",
    "title": "Funding Decisions",
    "version": 1
  },
  "approval_thresholds": {
    "staff_limit_cents": 20000,
    "admin_over_cents": 20000
  },
  "intent_counting": {
    "count_statuses": ["committed", "fulfilled"],
    "count_intent_kinds": ["pledge", "donation", "pass_through"]
  },
  "eligibility_rules": [
    {
      "id": "spend_basic_needs_welcome_home",
      "enabled": true,
      "ops": ["reserve", "encumber", "spend"],
      "spending_classes_any": ["basic_needs"],
      "allow_fund_keys": [
        "welcome_home_reimbursement",
        "general_unrestricted"
      ],
      "required_tags_any": ["welcome_home_kit"],
      "required_restrictions_all": [],
      "deny_if_restrictions_any": [],
      "priority": 100
    },
    {
      "id": "spend_admin_general",
      "enabled": true,
      "ops": ["reserve", "encumber", "spend"],
      "spending_classes_any": ["admin"],
      "allow_fund_keys": ["general_unrestricted", "general_restricted"],
      "required_tags_any": [],
      "required_restrictions_all": [],
      "deny_if_restrictions_any": [],
      "priority": 110
    },
    {
      "id": "receive_general_income",
      "enabled": true,
      "ops": ["receive"],
      "income_kinds_any": ["donation", "grant_disbursement", "reimbursement"],
      "allow_fund_keys": [
        "general_unrestricted",
        "general_restricted",
        "welcome_home_reimbursement"
      ],
      "required_tags_any": [],
      "required_restrictions_all": [],
      "deny_if_restrictions_any": [],
      "priority": 200
    }
  ],
  "approval_rules": [
    {
      "id": "approval_over_staff_cap",
      "enabled": true,
      "ops": ["encumber", "spend"],
      "min_amount_cents": 20001,
      "required_approvals": ["treasurer"],
      "selected_fund_keys_any": [],
      "priority": 100
    },
    {
      "id": "approval_restricted_fund",
      "enabled": true,
      "ops": ["encumber", "spend"],
      "min_amount_cents": 1,
      "required_approvals": ["treasurer"],
      "selected_fund_keys_any": [
        "general_restricted",
        "welcome_home_reimbursement"
      ],
      "priority": 110
    }
  ],
  "preference_order": [
    "welcome_home_reimbursement",
    "general_restricted",
    "general_unrestricted"
  ]
}
