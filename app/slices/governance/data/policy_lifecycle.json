        "default": "draft",
        "statuses": [
          {
            "can_issue": false,
            "code": "draft",
            "label": "Draft"
          },
          {
            "can_issue": false,
            "code": "review",
            "label": "Under review"
          },
          {
            "can_issue": true,
            "code": "active",
            "label": "Active"
          },
          {
            "can_issue": false,
            "code": "suspended",
            "label": "Suspended"
          }
        ]
      },
      "transitions": {
        "mou": {
          "active": [
            "expired",
            "terminated"
          ],
          "expired": [
