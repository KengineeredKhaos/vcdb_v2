            "returned"
          ],
          "received": [
            "inspected"
          ],
          "returned": [
            "inspected"
          ]
        }
      }
    },
    "resource": {
      "mou_status_allowed": [
        "none",
        "pending",
        "active",
        "expired",
        "terminated"
      ],
      "readiness": [
        "draft",
        "review",
        "active",
        "suspended"
      ]
    },
