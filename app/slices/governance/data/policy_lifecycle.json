          {
            "can_issue": false,
            "code": "none",
            "label": "No MOU"
          },
          {
            "can_issue": false,
            "code": "pending",
            "label": "MOU pending"
          },
          {
            "can_issue": true,
            "code": "active",
            "label": "Active MOU"
          },
          {
            "can_issue": false,
            "code": "expired",
            "label": "Expired MOU"
          },
          {
            "can_issue": false,
            "code": "terminated",
            "label": "Terminated"
          }
        ]
      },
      "pledge": {
        "statuses": [
          {
            "code": "proposed",
            "label": "Proposed"
          },
          {
            "code": "active",
            "label": "Active"
          },
          {
            "code": "fulfilled",
            "label": "Fulfilled"
          },
          {
            "code": "cancelled",
            "label": "Cancelled"
          }
        ]
      },
