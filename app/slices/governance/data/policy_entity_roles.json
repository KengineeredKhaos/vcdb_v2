{
  "meta": {
    "description": "Canonical domain role catalog and assignment rules.",
    "effective_on": "2026-03-13",
    "notes": [
      "assignment_rules define allowed domain-role combinations and ",
      "disallowed combinations by entity type.",
      "Governance business authority is not represented as an",
      " Entity domain role."
    ],
    "policy_key": "entity_roles",
    "schema_version": 1,
    "status": "draft",
    "title": "Entity Roles",
    "version": 2
  },
  "domain_roles": [
    "customer",
    "resource",
    "sponsor",
    "civilian"
  ],
  "assignment_rules": {
    "civilian": {
      "allowed": [
        "resource",
        "sponsor"
      ],
      "default": []
    },
    "customer": {
      "allowed": [],
      "default": []
    },
    "EntityPerson": {
      "allowed": [
        "customer",
        "civilian"
      ],
      "default": []
    },
    "EntityOrg": {
      "allowed": [
        "resource",
        "sponsor"
      ],
      "default": []
    },
    "disallow_roles": {
      "EntityOrg": [
        "customer",
        "civilian"
      ]
    }
  }
}
