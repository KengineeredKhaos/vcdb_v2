{
  "meta": {
    "policy_key": "entity_roles",
    "schema_version": 1,
    "status": "draft",
    "title": "Domain Roles",
    "version": 1,
    "effective_on": "2026-01-01",
    "description": "Allowed domain roles and domain↔RBAC assignment constraints.",
    "notes": [
      "This policy concerns Domain roles, rules & constraints.",
      "See Auth slice for RBAC roles and rules.",
      "See policy 'poc' for POC scope/rank constraints."
    ]

  },
  "domain_roles": [
    "governor",
    "staff",
    "customer",
    "resource",
    "sponsor",
    "civilian"
  ],
  "assignment_rules": {
    "domain_disallows_rbac": [
      "civilian"
    ],
    "forbidden_pairs": [
      [
        "civilian",
        "governor"
      ]
    ],
    "must_include_when_rbac": {
      "admin": [
        "governor"
      ],
      "staff": [
        "governor"
      ]
    },
    "rbac_can_assign": {
      "admin": [
        "governor",
        "staff",
        "customer",
        "resource",
        "sponsor",
        "civilian"
      ],
      "auditor": [
        "staff"
      ],
      "staff": [
        "governor"
      ],
      "user": [
        "customer",
        "resource",
        "sponsor",
        "civilian"
      ]
    }
  }
}
