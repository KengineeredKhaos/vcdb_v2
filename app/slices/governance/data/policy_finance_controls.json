{
  "meta": {
    "description": "Staff spending caps, approval thresholds, and budget periods.",
    "effective_on": "2026-03-13",
    "notes": [
      "This policy governs approval thresholds and budget-period metadata.",
      "Use semantic fund keys, not table or column names."
    ],
    "policy_key": "finance_controls",
    "schema_version": 1,
    "status": "draft",
    "title": "Finance Controls",
    "version": 2
  },
  "staff_cap_cents": 20000,
  "approval_rules": [
    {
      "rule_id": "appr-100-staff-cap",
      "priority": 100,
      "match": {
        "op": ["encumber", "spend"],
        "amount_cents_gt": 20000
      },
      "required_approvals": ["treasurer"],
      "reason_code": "over_staff_cap"
    },
    {
      "rule_id": "appr-120-restricted-funds-need-approver",
      "priority": 120,
      "match": {
        "op": ["encumber", "spend"],
        "selected_fund_keys_any": [
          "general_restricted",
          "welcome_home_reimbursement"
        ]
      },
      "required_approvals": ["treasurer"],
      "reason_code": "restricted_fund_requires_approval"
    }
  ],
  "budget_periods": [
    {
      "period_key": "annual",
      "label": "Annual",
      "start_month": 1,
      "start_day": 1
    }
  ],
  "budget_caps": []
}
