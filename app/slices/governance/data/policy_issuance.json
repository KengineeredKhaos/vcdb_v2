{
  "spending_staff_cap_cents": 20000,
  "default_behavior": "allow",

  "defaults": {
    "cadence": {
      "scope": "classification",
      "period_days": 30,
      "max_per_period": 1,
      "label": "default-per-30"
    }
  },

  "rules": [
    {
      "match": { "sku_parts": { "source": "DR" } },
      "qualifiers": { "veteran_required": true }
    },

    {
      "match": { "sku_parts": { "category": "CG", "subcategory": "SL", "source": "LC" } },
      "qualifiers": { "homeless_required": true }
    },

    {
      "match": { "classification_key": "UW/TP" },
      "cadence": { "scope": "classification", "period_days": 30, "max_per_period": 1 }
    },

    {
      "match": { "classification_key": "CG/SL" },
      "cadence": { "scope": "classification", "period_days": 90, "max_per_period": 1 }
    },

    {
      "match": { "sku_parts": { "category": "CG", "subcategory": "SL", "source": "DR" } },
      "qualifiers": { "homeless_required": true, "veteran_required": true },
      "cadence": { "scope": "sku", "period_days": 90, "max_per_period": 1, "label": "bag-per-90d" }
    },

    {
      "match": { "classification_key": "welcome_home.kit" },
      "qualifiers": { "veteran_required": true },
      "cadence": { "scope": "classification", "period_days": 180, "max_per_period": 1, "label": "WHK-per-180d" }
    }
  ]
}
