{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/policy_calendar.schema.json",
  "title": "VCDB Calendar Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "projects": {
      "type": "object",
      "description": "Per-project blackout rules",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "blackout_rules": {
            "type": "array",
            "items": {
              "oneOf": [
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "type": { "const": "weekday" },
                    "days": {
                      "type": "array",
                      "minItems": 1,
                      "items": { "type": "string", "enum": ["MON","TUE","WED","THU","FRI","SAT","SUN"] }
                    }
                  },
                  "required": ["type", "days"]
                },
                {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "type": { "const": "date_range" },
                    "start": { "type": "string", "format": "date" },
                    "end":   { "type": "string", "format": "date" }
                  },
                  "required": ["type", "start", "end"]
                }
              ]
            }
          }
        },
        "required": ["blackout_rules"]
      }
    }
  },
  "required": ["version", "projects"]
}
