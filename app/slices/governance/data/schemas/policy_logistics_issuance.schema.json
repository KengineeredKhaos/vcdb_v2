{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_logistics_issuance.schema.json",
  "title": "Logistics Issuance Policy Schema",
  "description": "Validates policy_logistics_issuance.json (issuance defaults/rules and SKU-derived constraints).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "qualifiers": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "veteran_required": {
          "type": "boolean"
        },
        "homeless_required": {
          "type": "boolean"
        }
      }
    },
    "skuPartsMatch": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "category": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "subcategory": {
          "type": "string",
          "pattern": "^[A-Z]{2}$"
        },
        "source": {
          "$ref": "#/$defs/tokenUpper2"
        }
      }
    },
    "match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "sku_parts": {
          "$ref": "#/$defs/skuPartsMatch"
        },
        "classification_key": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\n\\r]+$"
        }
      },
      "minProperties": 1
    },
    "issuanceRule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "if",
        "then",
        "why"
      ],
      "properties": {
        "if": {
          "type": "object",
          "additionalProperties": false,
          "minProperties": 1,
          "properties": {
            "category": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "subcategory": {
              "type": "string",
              "pattern": "^[A-Z]{2}$"
            },
            "source": {
              "$ref": "#/$defs/tokenUpper2"
            }
          }
        },
        "then": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "issuance_class"
          ],
          "properties": {
            "issuance_class": {
              "type": "string",
              "enum": [
                "V",
                "H",
                "D",
                "U"
              ]
            }
          }
        },
        "why": {
          "$ref": "#/$defs/singleLine"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "issuance",
    "sku_constraints"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "logistics_issuance"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "issuance": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaults",
        "rules"
      ],
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "cadence"
          ],
          "properties": {
            "cadence": {
              "$ref": "#/$defs/cadence"
            }
          }
        },
        "rules": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/issuanceRule"
          }
        }
      }
    },
    "sku_constraints": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed_units",
        "allowed_sources",
        "rules"
      ],
      "properties": {
        "allowed_units": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "allowed_sources": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/tokenUpper2"
          }
        },
        "rules": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "match"
            ],
            "properties": {
              "match": {
                "$ref": "#/$defs/match"
              },
              "qualifiers": {
                "$ref": "#/$defs/qualifiers"
              },
              "cadence": {
                "$ref": "#/$defs/cadence"
              }
            }
          }
        }
      }
    }
  }
}
