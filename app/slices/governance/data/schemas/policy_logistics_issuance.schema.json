{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "issuance": {
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "additionalProperties": false,
          "properties": {
            "cadence": {
              "additionalProperties": true,
              "properties": {
                "label": {
                  "type": "string"
                },
                "max_per_period": {
                  "minimum": 0,
                  "type": "integer"
                },
                "period_days": {
                  "minimum": 1,
                  "type": "integer"
                },
                "scope": {
                  "enum": [
                    "classification",
                    "sku"
                  ],
                  "type": "string"
                }
              },
              "required": [
                "max_per_period",
                "period_days",
                "scope"
              ],
              "type": "object"
            }
          },
          "required": [
            "cadence"
          ],
          "type": "object"
        },
        "rules": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "if": {
                "additionalProperties": true,
                "type": "object"
              },
              "then": {
                "additionalProperties": true,
                "type": "object"
              },
              "why": {
                "type": "string"
              }
            },
            "required": [
              "if",
              "then",
              "why"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "defaults",
        "rules"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective_on": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": "array"
        },
        "policy_key": {
          "pattern": "^[a-z0-9_]+$",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated"
          ],
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "title",
        "status"
      ],
      "type": "object"
    },
    "sku_constraints": {
      "additionalProperties": false,
      "properties": {
        "rules": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "cadence": {
                "additionalProperties": true,
                "properties": {
                  "label": {
                    "type": "string"
                  },
                  "max_per_period": {
                    "minimum": 0,
                    "type": "integer"
                  },
                  "period_days": {
                    "minimum": 1,
                    "type": "integer"
                  },
                  "scope": {
                    "enum": [
                      "classification",
                      "sku"
                    ],
                    "type": "string"
                  }
                },
                "required": [
                  "max_per_period",
                  "period_days",
                  "scope"
                ],
                "type": "object"
              },
              "match": {
                "additionalProperties": false,
                "properties": {
                  "classification_key": {
                    "type": "string"
                  },
                  "sku_parts": {
                    "additionalProperties": true,
                    "type": "object"
                  }
                },
                "type": "object"
              },
              "qualifiers": {
                "additionalProperties": false,
                "properties": {
                  "homeless_required": {
                    "type": "boolean"
                  },
                  "veteran_required": {
                    "type": "boolean"
                  }
                },
                "type": "object"
              }
            },
            "required": [
              "match"
            ],
            "type": "object"
          },
          "type": "array"
        }
      },
      "required": [
        "rules"
      ],
      "type": "object"
    }
  },
  "required": [
    "meta",
    "issuance",
    "sku_constraints"
  ],
  "title": "Logistics Issuance Policy",
  "type": "object"
}
