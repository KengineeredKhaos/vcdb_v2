{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_logistics_issuance.schema.json",
  "title": "Logistics Issuance Policy",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "meta"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_key": {
          "type": "string",
          "const": "logistics_issuance"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "title": { "type": "string", "minLength": 1 },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    }
  }
}
