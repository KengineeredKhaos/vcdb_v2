{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/policy_spending.schema.json",
  "title": "VCDB Spending Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "staff_cap_cents": { "type": "integer", "minimum": 0 },
    "class_caps": {
      "type": "object",
      "description": "Classification key → cap",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "cap_cents": { "type": "integer", "minimum": 0 }
        },
        "required": ["cap_cents"]
      }
    },
    "approvers": {
      "type": "object",
      "description": "Approval levels/titles",
      "additionalProperties": { "type": "string" }
    }
  },
  "required": ["version", "staff_cap_cents"]
}
