{
  "$defs": {
    "classificationNode": {
      "additionalProperties": {
        "$ref": "#/$defs/classificationNode"
      },
      "properties": {
        "attributes": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        }
      },
      "type": "object"
    },
    "classifications": {
      "additionalProperties": false,
      "properties": {
        "lifecycle": {
          "$ref": "#/$defs/lifecycle"
        },
        "map": {
          "additionalProperties": {
            "$ref": "#/$defs/classificationNode"
          },
          "type": "object"
        },
        "resource_capabilities": {
          "$ref": "#/$defs/resourceCapabilities"
        },
        "sku_code_regex": {
          "items": {
            "$ref": "#/$defs/regexString"
          },
          "minItems": 1,
          "type": "array"
        },
        "sponsor_capabilities": {
          "$ref": "#/$defs/sponsorCapabilities"
        }
      },
      "required": [
        "sku_code_regex",
        "map",
        "resource_capabilities",
        "sponsor_capabilities",
        "lifecycle"
      ],
      "type": "object"
    },
    "dateISO": {
      "format": "date",
      "type": "string"
    },
    "lifecycle": {
      "additionalProperties": false,
      "properties": {
        "resource": {
          "$ref": "#/$defs/lifecycleEntity"
        },
        "sponsor": {
          "$ref": "#/$defs/lifecycleEntity"
        }
      },
      "required": [
        "resource",
        "sponsor"
      ],
      "type": "object"
    },
    "lifecycleEntity": {
      "additionalProperties": false,
      "properties": {
        "mou_allowed": {
          "items": {
            "$ref": "#/$defs/mouStatus"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        },
        "readiness_allowed": {
          "items": {
            "$ref": "#/$defs/readinessStatus"
          },
          "minItems": 1,
          "type": "array",
          "uniqueItems": true
        }
      },
      "required": [
        "readiness_allowed",
        "mou_allowed"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "items": {
            "$ref": "#/$defs/singleLine"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "service_taxonomy",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "mouStatus": {
      "enum": [
        "none",
        "pending",
        "active",
        "expired",
        "terminated"
      ],
      "type": "string"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "readinessStatus": {
      "enum": [
        "draft",
        "review",
        "active",
        "suspended"
      ],
      "type": "string"
    },
    "regexString": {
      "minLength": 1,
      "type": "string"
    },
    "resourceCapabilities": {
      "additionalProperties": false,
      "properties": {
        "by_domain": {
          "additionalProperties": {
            "items": {
              "$ref": "#/$defs/tokenLower"
            },
            "type": "array"
          },
          "type": "object"
        }
      },
      "required": [
        "by_domain"
      ],
      "type": "object"
    },
    "singleLine": {
      "pattern": "^[^\\r\\n]*$",
      "type": "string"
    },
    "sponsorCapabilities": {
      "additionalProperties": false,
      "properties": {
        "domains": {
          "items": {
            "$ref": "#/$defs/sponsorCapabilityDomain"
          },
          "minItems": 1,
          "type": "array"
        },
        "meta": {
          "additionalProperties": false,
          "properties": {
            "flat_key_prefix": {
              "$ref": "#/$defs/singleLine"
            },
            "unclassified_key": {
              "$ref": "#/$defs/singleLine"
            }
          },
          "required": [
            "flat_key_prefix",
            "unclassified_key"
          ],
          "type": "object"
        }
      },
      "required": [
        "domains",
        "meta"
      ],
      "type": "object"
    },
    "sponsorCapabilityDomain": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/tokenLower"
        },
        "keys": {
          "items": {
            "$ref": "#/$defs/sponsorCapabilityKey"
          },
          "minItems": 1,
          "type": "array"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      },
      "required": [
        "code",
        "label",
        "keys"
      ],
      "type": "object"
    },
    "sponsorCapabilityKey": {
      "additionalProperties": false,
      "properties": {
        "code": {
          "$ref": "#/$defs/tokenLower"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      },
      "required": [
        "code",
        "label",
        "description"
      ],
      "type": "object"
    },
    "tokenLower": {
      "pattern": "^[a-z][a-z0-9_]*$",
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_service_taxonomy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_service_taxonomy.json (classifications tree, resource capabilities, sponsor capabilities, lifecycle).",
  "properties": {
    "classifications": {
      "$ref": "#/$defs/classifications"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    }
  },
  "required": [
    "meta",
    "classifications"
  ],
  "title": "Service Taxonomy Policy Schema",
  "type": "object"
}
