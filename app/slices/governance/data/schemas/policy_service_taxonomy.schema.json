{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_service_taxonomy.schema.json",
  "title": "Service Taxonomy Policy Schema",
  "description": "Validates policy_service_taxonomy.json (classifications map, resource capabilities, sponsor capabilities).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "attributeMap": {
      "type": "object",
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\n\\r]+$"
        }
      }
    },
    "classNode": {
      "type": "object",
      "properties": {
        "attributes": {
          "$ref": "#/$defs/attributeMap"
        }
      },
      "additionalProperties": {
        "$ref": "#/$defs/classNode"
      }
    },
    "capByDomain": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "$ref": "#/$defs/token"
        }
      }
    },
    "sponsorCapabilityKey": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "label",
        "description"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/token"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "sponsorDomain": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "label",
        "keys"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/token"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "keys": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/sponsorCapabilityKey"
          }
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "classifications"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "service_taxonomy"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "classifications": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "sku_code_regex",
        "map",
        "resource_capabilities",
        "sponsor_capabilities"
      ],
      "properties": {
        "sku_code_regex": {
          "description": "Regex (string) or list of regex strings used to validate classification codes parsed from SKUs.",
          "oneOf": [
            {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^\\n\\r]+$"
            },
            {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "string",
                "minLength": 1,
                "pattern": "^[^\\n\\r]+$"
              }
            }
          ]
        },
        "map": {
          "$ref": "#/$defs/classNode"
        },
        "resource_capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "by_domain"
          ],
          "properties": {
            "by_domain": {
              "$ref": "#/$defs/capByDomain"
            }
          }
        },
        "sponsor_capabilities": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "domains",
            "meta"
          ],
          "properties": {
            "domains": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/sponsorDomain"
              }
            },
            "meta": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "flat_key_prefix",
                "unclassified_key"
              ],
              "properties": {
                "flat_key_prefix": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[^\\n\\r]+$"
                },
                "unclassified_key": {
                  "type": "string",
                  "minLength": 1,
                  "pattern": "^[^\\n\\r]+$"
                }
              }
            }
          }
        }
      }
    }
  }
}
