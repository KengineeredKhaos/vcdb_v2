{
  "$defs": {
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "kinds": {
      "items": {
        "$ref": "#/$defs/token"
      },
      "minItems": 1,
      "type": "array"
    },
    "locations": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "code": {
            "$ref": "#/$defs/singleLine"
          },
          "kind": {
            "$ref": "#/$defs/token"
          },
          "name": {
            "$ref": "#/$defs/singleLine"
          }
        },
        "required": [
          "code",
          "kind",
          "name"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "locations",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "patterns": {
      "additionalProperties": {
        "minLength": 1,
        "pattern": "^[^\\n\\r]+$",
        "type": "string"
      },
      "description": "Optional regex patterns to validate codes by kind.",
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_locations.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_locations.json (location kinds, locations list, and code patterns).",
  "properties": {
    "kinds": {
      "$ref": "#/$defs/kinds"
    },
    "locations": {
      "$ref": "#/$defs/locations"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "patterns": {
      "$ref": "#/$defs/patterns"
    }
  },
  "required": [
    "meta",
    "kinds",
    "locations",
    "patterns"
  ],
  "title": "Locations Policy Schema",
  "type": "object"
}
