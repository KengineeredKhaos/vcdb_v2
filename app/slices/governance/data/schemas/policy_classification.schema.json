{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/policy_classification.schema.json",
  "title": "VCDB Classification Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "classifications": {
      "type": "object",
      "description": "Taxonomy key → metadata",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "attributes": {
            "type": "object",
            "description": "Free-form attribute hints (e.g., size list)",
            "additionalProperties": {
              "oneOf": [
                { "type": "array", "items": { "type": "string" } },
                { "type": "string" },
                { "type": "number" },
                { "type": "boolean" }
              ]
            }
          }
        }
      }
    },
    "sku_code_regex": { "type": "string" }
  },
  "required": ["version", "classifications"]
}
