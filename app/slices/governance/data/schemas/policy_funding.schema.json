{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/policy_funding.schema.json",
  "title": "VCDB Funding Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "fund_archetypes": {
      "type": "array",
      "description": "Canonical list of fund archetype codes and restrictions.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "key":        { "type": "string", "minLength": 1 },
          "restriction": {
            "type": "string",
            "enum": ["unrestricted", "temporarily_restricted"]
          },
          "label":      { "type": "string", "minLength": 1 }
        },
        "required": ["key", "restriction"]
      }
    },
    "projects": {
      "type": "object",
      "description": "Project ULID → allow-list of classification patterns",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "allow_classifications": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["allow_classifications"]
      }
    },
    "sponsors": {
      "type": "object",
      "description": "Sponsor ULID → deny-list of classification patterns",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "deny_classifications": {
            "type": "array",
            "items": { "type": "string" }
          }
        },
        "required": ["deny_classifications"]
      }
    }
  },
  "required": ["version"]
}
