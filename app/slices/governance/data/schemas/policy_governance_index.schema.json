{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_governance_index.schema.json",
  "title": "Governance Policy Index",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "catalog_version",
    "meta",
    "policies"
  ],
  "properties": {
    "catalog_version": {
      "type": "string",
      "minLength": 1
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_key": {
          "type": "string",
          "const": "governance_index"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "title": { "type": "string", "minLength": 1 },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_key",
          "filename",
          "schema_filename",
          "owner_role_hint",
          "edit_cadence_hint",
          "notes"
        ],
        "properties": {
          "policy_key": {
            "type": "string",
            "pattern": "^[a-z0-9_]+$"
          },
          "filename": {
            "type": "string",
            "pattern": "^policy_[a-z0-9_]+\\.json$"
          },
          "schema_filename": {
            "type": "string",
            "pattern": "^schemas/policy_[a-z0-9_]+\\.schema\\.json$"
          },
          "owner_role_hint": {
            "type": "string",
            "minLength": 1
          },
          "edit_cadence_hint": {
            "type": "string",
            "enum": ["rare", "occasional", "frequent"]
          },
          "notes": {
            "type": "array",
            "items": { "type": "string" }
          }
        }
      }
    }
  }
}
