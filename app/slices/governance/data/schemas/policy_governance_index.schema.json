{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "catalog_version": {
      "type": "string"
    },
    "meta": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective_on": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": "array"
        },
        "policy_key": {
          "pattern": "^[a-z0-9_]+$",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated"
          ],
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "title",
        "status"
      ],
      "type": "object"
    },
    "policies": {
      "items": {
        "additionalProperties": true,
        "properties": {
          "edit_cadence_hint": {
            "type": "string"
          },
          "filename": {
            "type": "string"
          },
          "notes": {
            "items": {
              "type": [
                "string",
                "null"
              ]
            },
            "type": "array"
          },
          "owner_role_hint": {
            "type": "string"
          },
          "policy_key": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          },
          "schema_filename": {
            "type": "string"
          }
        },
        "required": [
          "policy_key",
          "filename",
          "schema_filename"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    }
  },
  "required": [
    "catalog_version",
    "meta",
    "policies"
  ],
  "title": "Governance Policy Index",
  "type": "object"
}
