{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_governance_index.schema.json",
  "title": "Governance Policy Index Schema",
  "description": "Validates policy_governance_index.json (Policy Catalog v2.0).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "catalog_version",
    "policies"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "governance_index"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "catalog_version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+$"
    },
    "policies": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "policy_key",
          "filename",
          "schema_filename"
        ],
        "properties": {
          "policy_key": {
            "$ref": "#/$defs/token"
          },
          "filename": {
            "type": "string",
            "pattern": "^policy_[a-z0-9_]+\\.json$"
          },
          "schema_filename": {
            "type": "string",
            "pattern": "^schemas/policy_[a-z0-9_]+\\.schema\\.json$"
          },
          "owner_role_hint": {
            "$ref": "#/$defs/token"
          },
          "edit_cadence_hint": {
            "type": "string",
            "enum": [
              "rare",
              "occasional",
              "frequent"
            ]
          },
          "notes": {
            "type": "array",
            "items": {
              "type": "string",
              "maxLength": 70,
              "pattern": "^[^\\n\\r]*$"
            },
            "default": []
          }
        }
      }
    }
  }
}
