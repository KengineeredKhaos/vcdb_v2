{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VCDB Budget Caps Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "periods": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "period_label": { "type": "string", "minLength": 1 },
          "lines": {
            "type": "array",
            "items": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "fund_archetype_key": { "type": "string", "minLength": 1 },
                "fund_code":          { "type": "string" },
                "project_type_key":   { "type": "string", "minLength": 1 },
                "project_code":       { "type": "string" },
                "amount_cents":       { "type": "integer", "minimum": 0 },
                "source":             { "type": "string" },
                "status": {
                  "type": "string",
                  "enum": ["draft", "adopted"]
                }
              },
              "required": ["fund_archetype_key", "project_type_key", "amount_cents", "status"]
            }
          }
        },
        "required": ["period_label", "lines"]
      }
    }
  },
  "required": ["version"]
}
