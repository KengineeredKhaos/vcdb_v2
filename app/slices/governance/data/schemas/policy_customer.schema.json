{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_customer.schema.json",
  "title": "Customer Policy Schema",
  "description": "Validates policy_customer.json (eligibility, needs tiers, verification methods).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "veteran_verification",
    "needs_tiers",
    "eligibility"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "customer"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "veteran_verification": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "methods"
      ],
      "properties": {
        "methods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/token"
          }
        }
      }
    },
    "needs_tiers": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "tier1",
        "tier2",
        "tier3"
      ],
      "properties": {
        "tier1": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "tier2": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "tier3": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        }
      }
    },
    "eligibility": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "defaults",
        "map"
      ],
      "properties": {
        "defaults": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "tier1_min",
            "tier2_min",
            "tier3_min"
          ],
          "properties": {
            "tier1_min": {
              "type": "integer",
              "minimum": 0
            },
            "tier2_min": {
              "type": "integer",
              "minimum": 0
            },
            "tier3_min": {
              "type": "integer",
              "minimum": 0
            }
          }
        },
        "map": {
          "type": "object",
          "description": "Maps semantic eligibility qualifiers to slice-owned factor keys (string identifiers).",
          "minProperties": 1,
          "additionalProperties": {
            "type": "string",
            "minLength": 1,
            "pattern": "^[^\\n\\r]+$"
          }
        }
      }
    }
  }
}
