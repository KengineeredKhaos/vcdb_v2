{
  "$defs": {
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "eligibility": {
      "additionalProperties": false,
      "properties": {
        "defaults": {
          "additionalProperties": false,
          "properties": {
            "tier1_min": {
              "minimum": 0,
              "type": "integer"
            },
            "tier2_min": {
              "minimum": 0,
              "type": "integer"
            },
            "tier3_min": {
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "tier1_min",
            "tier2_min",
            "tier3_min"
          ],
          "type": "object"
        },
        "map": {
          "additionalProperties": {
            "minLength": 1,
            "pattern": "^[^\\n\\r]+$",
            "type": "string"
          },
          "description": "Maps semantic eligibility qualifiers to slice-owned factor keys (string identifiers).",
          "minProperties": 1,
          "type": "object"
        }
      },
      "required": [
        "defaults",
        "map"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "customer",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "needs_tiers": {
      "additionalProperties": false,
      "properties": {
        "tier1": {
          "items": {
            "$ref": "#/$defs/token"
          },
          "type": "array"
        },
        "tier2": {
          "items": {
            "$ref": "#/$defs/token"
          },
          "type": "array"
        },
        "tier3": {
          "items": {
            "$ref": "#/$defs/token"
          },
          "type": "array"
        }
      },
      "required": [
        "tier1",
        "tier2",
        "tier3"
      ],
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "veteran_verification": {
      "additionalProperties": false,
      "properties": {
        "methods": {
          "items": {
            "$ref": "#/$defs/token"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "methods"
      ],
      "type": "object"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_customer.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_customer.json (eligibility, needs tiers, verification methods).",
  "properties": {
    "eligibility": {
      "$ref": "#/$defs/eligibility"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "needs_tiers": {
      "$ref": "#/$defs/needs_tiers"
    },
    "veteran_verification": {
      "$ref": "#/$defs/veteran_verification"
    }
  },
  "required": [
    "meta",
    "veteran_verification",
    "needs_tiers",
    "eligibility"
  ],
  "title": "Customer Policy Schema",
  "type": "object"
}
