{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "policy_sponsor_capabilities.schema.json",
  "title": "Sponsor Capabilities Policy",
  "type": "object",
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "caps": {
      "type": "object",
      "description": "Capability domains and their allowed keys.",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "array",
        "description": "List of capability codes within this domain.",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      }
    },
    "meta": {
      "type": "object",
      "description": "Optional extra metadata (e.g. unclassified key, notes).",
      "additionalProperties": true
    }
  },
  "required": ["caps"],
  "additionalProperties": false
}
