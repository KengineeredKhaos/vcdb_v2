{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_lifecycle.schema.json",
  "title": "Lifecycle Policy Schema",
  "description": "Validates policy_lifecycle.json (state machines and allowed transitions).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "transitionMap": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "minItems": 0,
        "items": {
          "type": "string",
          "minLength": 1,
          "pattern": "^[^\\n\\r]+$"
        }
      }
    },
    "statusObj": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "code",
        "label"
      ],
      "properties": {
        "code": {
          "$ref": "#/$defs/token"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "can_issue": {
          "type": "boolean"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "machines"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "lifecycle"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "machines": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "logistics",
        "resource",
        "sponsor"
      ],
      "properties": {
        "logistics": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "item_lifecycle"
          ],
          "properties": {
            "item_lifecycle": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "states",
                "transitions"
              ],
              "properties": {
                "states": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/token"
                  }
                },
                "transitions": {
                  "$ref": "#/$defs/transitionMap"
                }
              }
            }
          }
        },
        "resource": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readiness",
            "mou_status_allowed"
          ],
          "properties": {
            "readiness": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/token"
              }
            },
            "mou_status_allowed": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/token"
              }
            }
          }
        },
        "sponsor": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "readiness",
            "mou",
            "pledge",
            "transitions"
          ],
          "properties": {
            "readiness": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "default",
                "statuses"
              ],
              "properties": {
                "default": {
                  "$ref": "#/$defs/token"
                },
                "statuses": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  }
                }
              }
            },
            "mou": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "default",
                "statuses"
              ],
              "properties": {
                "default": {
                  "$ref": "#/$defs/token"
                },
                "statuses": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  }
                }
              }
            },
            "pledge": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "statuses"
              ],
              "properties": {
                "statuses": {
                  "type": "array",
                  "minItems": 1,
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  }
                }
              }
            },
            "transitions": {
              "type": "object",
              "additionalProperties": false,
              "required": [
                "readiness",
                "mou",
                "pledge"
              ],
              "properties": {
                "readiness": {
                  "$ref": "#/$defs/transitionMap"
                },
                "mou": {
                  "$ref": "#/$defs/transitionMap"
                },
                "pledge": {
                  "$ref": "#/$defs/transitionMap"
                }
              }
            }
          }
        }
      }
    }
  }
}
