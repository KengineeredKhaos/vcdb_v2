{
  "$defs": {
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "machines": {
      "additionalProperties": true,
      "properties": {
        "logistics": {
          "additionalProperties": false,
          "properties": {
            "item_lifecycle": {
              "additionalProperties": false,
              "properties": {
                "states": {
                  "items": {
                    "$ref": "#/$defs/token"
                  },
                  "minItems": 1,
                  "type": "array"
                },
                "transitions": {
                  "$ref": "#/$defs/transitionMap"
                }
              },
              "required": [
                "states",
                "transitions"
              ],
              "type": "object"
            }
          },
          "required": [
            "item_lifecycle"
          ],
          "type": "object"
        },
        "resource": {
          "additionalProperties": false,
          "properties": {
            "mou_status_allowed": {
              "items": {
                "$ref": "#/$defs/token"
              },
              "minItems": 1,
              "type": "array"
            },
            "readiness": {
              "items": {
                "$ref": "#/$defs/token"
              },
              "minItems": 1,
              "type": "array"
            }
          },
          "required": [
            "readiness",
            "mou_status_allowed"
          ],
          "type": "object"
        },
        "sponsor": {
          "additionalProperties": false,
          "properties": {
            "mou": {
              "additionalProperties": false,
              "properties": {
                "default": {
                  "$ref": "#/$defs/token"
                },
                "statuses": {
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "default",
                "statuses"
              ],
              "type": "object"
            },
            "pledge": {
              "additionalProperties": false,
              "properties": {
                "statuses": {
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "statuses"
              ],
              "type": "object"
            },
            "readiness": {
              "additionalProperties": false,
              "properties": {
                "default": {
                  "$ref": "#/$defs/token"
                },
                "statuses": {
                  "items": {
                    "$ref": "#/$defs/statusObj"
                  },
                  "minItems": 1,
                  "type": "array"
                }
              },
              "required": [
                "default",
                "statuses"
              ],
              "type": "object"
            },
            "transitions": {
              "additionalProperties": false,
              "properties": {
                "mou": {
                  "$ref": "#/$defs/transitionMap"
                },
                "pledge": {
                  "$ref": "#/$defs/transitionMap"
                },
                "readiness": {
                  "$ref": "#/$defs/transitionMap"
                }
              },
              "required": [
                "readiness",
                "mou",
                "pledge"
              ],
              "type": "object"
            }
          },
          "required": [
            "readiness",
            "mou",
            "pledge",
            "transitions"
          ],
          "type": "object"
        }
      },
      "required": [
        "logistics",
        "resource",
        "sponsor"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "lifecycle",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "statusObj": {
      "additionalProperties": false,
      "properties": {
        "can_issue": {
          "type": "boolean"
        },
        "code": {
          "$ref": "#/$defs/token"
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      },
      "required": [
        "code",
        "label"
      ],
      "type": "object"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "transitionMap": {
      "additionalProperties": {
        "items": {
          "minLength": 1,
          "pattern": "^[^\\n\\r]+$",
          "type": "string"
        },
        "minItems": 0,
        "type": "array"
      },
      "minProperties": 1,
      "type": "object"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_lifecycle.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_lifecycle.json (state machines and allowed transitions).",
  "properties": {
    "machines": {
      "$ref": "#/$defs/machines"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    }
  },
  "required": [
    "meta",
    "machines"
  ],
  "title": "Lifecycle Policy Schema",
  "type": "object"
}
