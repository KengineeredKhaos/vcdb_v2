{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VCDB SKU Constraints Policy",
  "type": "object",
  "required": ["version", "rules", "allowed_units", "allowed_sources"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },

    "rules": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["if", "then"],
        "properties": {
          "if": {
            "type": "object",
            "properties": {
              "category": { "type": "string" },
              "subcategory": { "type": "string" },
              "source": { "type": "string" },
              "size": { "type": "string" },
              "color": { "type": "string" },
              "issuance_class": { "type": "string" }
            },
            "additionalProperties": false
          },
          "then": {
            "type": "object",
            "properties": {
              "issuance_class": {
                "type": "string",
                "enum": ["V", "H", "D", "U"]
              }
            },
            "required": ["issuance_class"],
            "additionalProperties": false
          },
          "why": { "type": "string" }
        },
        "additionalProperties": false
      }
    },

    "allowed_units": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["each", "lbs", "kit", "box", "pack"]
      },
      "minItems": 1,
      "uniqueItems": true
    },

    "allowed_sources": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["donation", "purchase", "transfer", "drmo"]
      },
      "minItems": 1,
      "uniqueItems": true
    }
  }
}
