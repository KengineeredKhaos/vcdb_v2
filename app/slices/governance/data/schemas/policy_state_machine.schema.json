{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/policy_state_machine.schema.json",
  "title": "VCDB State Machine Policy",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "machines": {
      "type": "object",
      "description": "Machine key → states + transitions",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "states": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          },
          "transitions": {
            "type": "object",
            "description": "from_state → [to_state, ...]",
            "additionalProperties": {
              "type": "array",
              "minItems": 1,
              "items": { "type": "string", "minLength": 1 }
            }
          }
        },
        "required": ["states", "transitions"]
      }
    }
  },
  "required": ["version", "machines"]
}
