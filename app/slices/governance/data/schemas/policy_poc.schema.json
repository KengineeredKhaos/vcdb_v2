{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_poc.schema.json",
  "title": "POC Policy",
  "description": "Validation for governance policy that constrains POC linkage behavior.",
  "type": "object",
  "additionalProperties": false,
  "required": ["poc_scopes", "default_scope", "max_rank"],
  "properties": {
    "poc_scopes": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/scopeString" }
    },
    "default_scope": { "$ref": "#/$defs/scopeString" },
    "max_rank": { "type": "integer", "minimum": 0, "maximum": 99 }
  },
  "$defs": {
    "scopeString": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,23}$"
    }
  }
}
