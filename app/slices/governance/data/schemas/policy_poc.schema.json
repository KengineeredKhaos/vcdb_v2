{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["meta", "poc_scopes", "default_scope", "max_rank"],
  "properties": {
    "meta": { "type": "object" },
    "poc_scopes": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "default_scope": { "type": "string" },
    "max_rank": { "type": "integer", "minimum": 0, "maximum": 99 }
  },
  "additionalProperties": false
}
