{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_operations.schema.json",
  "title": "Operations Policy Schema",
  "description": "Validates policy_operations.json (task kinds, finance hints, and project blackout rules).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "weekday": {
      "type": "string",
      "enum": [
        "MON",
        "TUE",
        "WED",
        "THU",
        "FRI",
        "SAT",
        "SUN"
      ]
    },
    "blackoutRule": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "days"
          ],
          "properties": {
            "type": {
              "const": "weekday"
            },
            "days": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/weekday"
              }
            }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "type",
            "start",
            "end"
          ],
          "properties": {
            "type": {
              "const": "date_range"
            },
            "start": {
              "$ref": "#/$defs/dateISO"
            },
            "end": {
              "$ref": "#/$defs/dateISO"
            }
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "defaults",
    "task_kinds",
    "projects"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "operations"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "defaults": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "finance_hints"
      ],
      "properties": {
        "finance_hints": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "expense_kinds"
          ],
          "properties": {
            "expense_kinds": {
              "type": "array",
              "minItems": 1,
              "items": {
                "$ref": "#/$defs/token"
              }
            }
          }
        }
      }
    },
    "task_kinds": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "key",
          "label",
          "finance_hints"
        ],
        "properties": {
          "key": {
            "$ref": "#/$defs/token"
          },
          "label": {
            "$ref": "#/$defs/singleLine"
          },
          "finance_hints": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "expense_kinds"
            ],
            "properties": {
              "expense_kinds": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "$ref": "#/$defs/token"
                }
              }
            }
          }
        }
      }
    },
    "projects": {
      "type": "object",
      "propertyNames": {
        "$ref": "#/$defs/ulid"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "blackout_rules"
        ],
        "properties": {
          "blackout_rules": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/blackoutRule"
            },
            "default": []
          }
        }
      }
    }
  }
}
