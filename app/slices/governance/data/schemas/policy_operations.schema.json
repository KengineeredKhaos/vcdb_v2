{
  "$defs": {
    "blackoutRule": {
      "oneOf": [
        {
          "additionalProperties": false,
          "properties": {
            "days": {
              "items": {
                "$ref": "#/$defs/weekday"
              },
              "minItems": 1,
              "type": "array"
            },
            "type": {
              "const": "weekday"
            }
          },
          "required": [
            "type",
            "days"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "properties": {
            "end": {
              "$ref": "#/$defs/dateISO"
            },
            "start": {
              "$ref": "#/$defs/dateISO"
            },
            "type": {
              "const": "date_range"
            }
          },
          "required": [
            "type",
            "start",
            "end"
          ],
          "type": "object"
        }
      ]
    },
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "defaults": {
      "additionalProperties": false,
      "properties": {
        "finance_hints": {
          "additionalProperties": false,
          "properties": {
            "expense_kinds": {
              "items": {
                "$ref": "#/$defs/token"
              },
              "minItems": 1,
              "type": "array"
            }
          },
          "required": [
            "expense_kinds"
          ],
          "type": "object"
        }
      },
      "required": [
        "finance_hints"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "operations",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "projects": {
      "additionalProperties": {
        "additionalProperties": false,
        "properties": {
          "blackout_rules": {
            "default": [],
            "items": {
              "$ref": "#/$defs/blackoutRule"
            },
            "type": "array"
          }
        },
        "required": [
          "blackout_rules"
        ],
        "type": "object"
      },
      "propertyNames": {
        "$ref": "#/$defs/ulid"
      },
      "type": "object"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "task_kinds": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "finance_hints": {
            "additionalProperties": false,
            "properties": {
              "expense_kinds": {
                "items": {
                  "$ref": "#/$defs/token"
                },
                "minItems": 1,
                "type": "array"
              }
            },
            "required": [
              "expense_kinds"
            ],
            "type": "object"
          },
          "key": {
            "$ref": "#/$defs/token"
          },
          "label": {
            "$ref": "#/$defs/singleLine"
          }
        },
        "required": [
          "key",
          "label",
          "finance_hints"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    },
    "weekday": {
      "enum": [
        "MON",
        "TUE",
        "WED",
        "THU",
        "FRI",
        "SAT",
        "SUN"
      ],
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_operations.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_operations.json (task kinds, finance hints, and project blackout rules).",
  "properties": {
    "defaults": {
      "$ref": "#/$defs/defaults"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "projects": {
      "$ref": "#/$defs/projects"
    },
    "task_kinds": {
      "$ref": "#/$defs/task_kinds"
    }
  },
  "required": [
    "meta",
    "defaults",
    "task_kinds",
    "projects"
  ],
  "title": "Operations Policy Schema",
  "type": "object"
}
