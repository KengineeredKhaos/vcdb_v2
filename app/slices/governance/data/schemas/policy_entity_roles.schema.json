{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_entity_roles.schema.json",
  "title": "Entity Roles Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "domain_roles",
    "assignment_rules"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "policy_key": {
          "type": "string",
          "const": "entity_roles"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "deprecated"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "domain_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      }
    },
    "assignment_rules": {
      "type": "object",
      "minProperties": 1,
      "propertyNames": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]*$"
      },
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "allowed",
          "default"
        ],
        "properties": {
          "allowed": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          },
          "default": {
            "type": "array",
            "uniqueItems": true,
            "items": {
              "type": "string",
              "pattern": "^[a-z][a-z0-9_]*$"
            }
          }
        }
      }
    }
  }
}
