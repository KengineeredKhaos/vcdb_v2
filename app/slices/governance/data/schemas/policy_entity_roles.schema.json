{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_entity_roles.schema.json",
  "title": "policy_entity_roles",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "domain_roles",
    "assignment_rules"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": {
          "type": "string",
          "minLength": 1
        },
        "effective_on": {
          "type": "string",
          "format": "date"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "policy_key": {
          "const": "entity_roles"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "active",
            "retired"
          ]
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "domain_roles": {
      "type": "array",
      "uniqueItems": true,
      "minItems": 4,
      "items": {
        "$ref": "#/$defs/domain_role"
      }
    },
    "assignment_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "civilian",
        "customer",
        "EntityPerson",
        "EntityOrg",
        "disallow_roles"
      ],
      "properties": {
        "civilian": {
          "$ref": "#/$defs/rule_block"
        },
        "customer": {
          "$ref": "#/$defs/rule_block"
        },
        "EntityPerson": {
          "$ref": "#/$defs/rule_block"
        },
        "EntityOrg": {
          "$ref": "#/$defs/rule_block"
        },
        "disallow_roles": {
          "type": "object",
          "additionalProperties": false,
          "required": [
            "EntityOrg"
          ],
          "properties": {
            "EntityOrg": {
              "type": "array",
              "uniqueItems": true,
              "items": {
                "$ref": "#/$defs/domain_role"
              }
            }
          }
        }
      }
    }
  },
  "$defs": {
    "domain_role": {
      "type": "string",
      "enum": [
        "customer",
        "resource",
        "sponsor",
        "civilian"
      ]
    },
    "rule_block": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "allowed",
        "default"
      ],
      "properties": {
        "allowed": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/domain_role"
          }
        },
        "default": {
          "type": "array",
          "uniqueItems": true,
          "items": {
            "$ref": "#/$defs/domain_role"
          }
        }
      }
    }
  }
}
