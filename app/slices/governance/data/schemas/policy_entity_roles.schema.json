{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "assignment_rules": {
      "additionalProperties": true,
      "properties": {
        "domain_disallows_rbac": {
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "forbidden_pairs": {
          "items": {
            "items": {
              "type": "string"
            },
            "maxItems": 2,
            "minItems": 2,
            "type": "array"
          },
          "type": "array"
        },
        "must_include_when_rbac": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        },
        "rbac_can_assign": {
          "additionalProperties": {
            "items": {
              "type": "string"
            },
            "type": "array"
          },
          "type": "object"
        }
      },
      "required": [
        "rbac_can_assign"
      ],
      "type": "object"
    },
    "domain_roles": {
      "items": {
        "pattern": "^[a-z0-9_]+$",
        "type": "string"
      },
      "minItems": 1,
      "type": "array",
      "uniqueItems": true
    },
    "meta": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective_on": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": "array"
        },
        "policy_key": {
          "pattern": "^[a-z0-9_]+$",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated"
          ],
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "title",
        "status"
      ],
      "type": "object"
    }
  },
  "required": [
    "meta",
    "domain_roles",
    "assignment_rules"
  ],
  "title": "Entity Roles Policy",
  "type": "object"
}
