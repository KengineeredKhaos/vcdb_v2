{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_entity_roles.schema.json",
  "title": "Entity Roles Policy Schema",
  "description": "Validates policy_entity_roles.json (domain roles, assignment rules, and POC scopes).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "domain_roles",
    "assignment_rules",
    "poc_rules"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "entity_roles"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "domain_roles": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/token"
      }
    },
    "assignment_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rbac_can_assign",
        "must_include_when_rbac",
        "forbidden_pairs",
        "domain_disallows_rbac"
      ],
      "properties": {
        "rbac_can_assign": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "minItems": 0,
            "items": {
              "$ref": "#/$defs/token"
            }
          }
        },
        "must_include_when_rbac": {
          "type": "object",
          "additionalProperties": {
            "type": "array",
            "items": {
              "$ref": "#/$defs/token"
            }
          }
        },
        "forbidden_pairs": {
          "type": "array",
          "items": {
            "type": "array",
            "minItems": 2,
            "maxItems": 2,
            "items": {
              "$ref": "#/$defs/token"
            }
          }
        },
        "domain_disallows_rbac": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/token"
          }
        }
      }
    },
    "poc_rules": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "poc_scopes",
        "default_scope",
        "max_rank"
      ],
      "properties": {
        "poc_scopes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "$ref": "#/$defs/token"
          }
        },
        "default_scope": {
          "$ref": "#/$defs/token"
        },
        "max_rank": {
          "type": "integer",
          "minimum": 1,
          "maximum": 99
        }
      }
    }
  }
}
