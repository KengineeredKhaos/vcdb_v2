{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "fund_archetypes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          },
          "label": {
            "type": "string"
          },
          "payment_timing": {
            "enum": [
              "upfront",
              "reimbursement"
            ],
            "type": "string"
          },
          "restriction_type": {
            "enum": [
              "unrestricted",
              "temporarily_restricted",
              "permanently_restricted"
            ],
            "type": "string"
          }
        },
        "required": [
          "key",
          "label",
          "payment_timing",
          "restriction_type"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "journal_flags": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "pattern": "^[a-z0-9_]+$",
            "type": "string"
          },
          "label": {
            "type": "string"
          }
        },
        "required": [
          "key",
          "label"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "meta": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective_on": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": "array"
        },
        "policy_key": {
          "pattern": "^[a-z0-9_]+$",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated"
          ],
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "title",
        "status"
      ],
      "type": "object"
    }
  },
  "required": [
    "meta",
    "fund_archetypes",
    "journal_flags"
  ],
  "title": "Finance Taxonomy Policy",
  "type": "object"
}
