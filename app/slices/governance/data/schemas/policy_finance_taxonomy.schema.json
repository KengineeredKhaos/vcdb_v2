{
  "$defs": {
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "expense_kinds": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "$ref": "#/$defs/token"
          },
          "label": {
            "$ref": "#/$defs/singleLine"
          }
        },
        "required": [
          "key",
          "label"
        ],
        "type": "object"
      },
      "type": "array"
    },
    "fund_archetypes": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "$ref": "#/$defs/token"
          },
          "label": {
            "$ref": "#/$defs/singleLine"
          },
          "payment_timing": {
            "enum": [
              "upfront",
              "reimbursement"
            ],
            "type": "string"
          },
          "restriction_type": {
            "enum": [
              "unrestricted",
              "temporarily_restricted"
            ],
            "type": "string"
          }
        },
        "required": [
          "key",
          "label",
          "restriction_type",
          "payment_timing"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "journal_flags": {
      "items": {
        "additionalProperties": false,
        "properties": {
          "key": {
            "$ref": "#/$defs/token"
          },
          "label": {
            "$ref": "#/$defs/singleLine"
          }
        },
        "required": [
          "key",
          "label"
        ],
        "type": "object"
      },
      "minItems": 1,
      "type": "array"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "finance_taxonomy",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "sponsor": {
      "additionalProperties": false,
      "properties": {
        "pledge_type": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "code": {
                "$ref": "#/$defs/token"
              },
              "label": {
                "$ref": "#/$defs/singleLine"
              }
            },
            "required": [
              "code",
              "label"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "pledge_type"
      ],
      "type": "object"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_finance_taxonomy.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_finance_taxonomy.json (fund archetypes, journal flags, and sponsor pledge types).",
  "properties": {
    "expense_kinds": {
      "$ref": "#/$defs/expense_kinds"
    },
    "fund_archetypes": {
      "$ref": "#/$defs/fund_archetypes"
    },
    "journal_flags": {
      "$ref": "#/$defs/journal_flags"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "sponsor": {
      "$ref": "#/$defs/sponsor"
    }
  },
  "required": [
    "meta",
    "fund_archetypes",
    "journal_flags",
    "sponsor"
  ],
  "title": "Finance Taxonomy Policy Schema",
  "type": "object"
}
