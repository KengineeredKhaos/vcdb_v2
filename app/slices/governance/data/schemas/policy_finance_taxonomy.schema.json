{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_finance_taxonomy.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "fund_keys",
    "restriction_keys",
    "income_kinds",
    "expense_kinds",
    "spending_classes"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },

    "fund_keys": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/semantic_key" },
      "additionalProperties": { "$ref": "#/$defs/fund_def" }
    },

    "restriction_keys": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/semantic_key" },
      "additionalProperties": { "$ref": "#/$defs/labeled_def" }
    },

    "income_kinds": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/semantic_key" },
      "additionalProperties": { "$ref": "#/$defs/labeled_def" }
    },

    "expense_kinds": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/semantic_key" },
      "additionalProperties": { "$ref": "#/$defs/labeled_def" }
    },

    "spending_classes": {
      "type": "object",
      "propertyNames": { "$ref": "#/$defs/semantic_key" },
      "additionalProperties": { "$ref": "#/$defs/labeled_def" }
    }
  },

  "$defs": {
    "semantic_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },

    "labeled_def": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label"],
      "properties": {
        "label": { "type": "string", "minLength": 1 }
      }
    },

    "fund_archetype": {
      "type": "string",
      "enum": [
        "unrestricted",
        "temporarily_restricted",
        "permanently_restricted"
      ]
    },

    "fund_def": {
      "type": "object",
      "additionalProperties": false,
      "required": ["label", "archetype", "default_restriction_keys"],
      "properties": {
        "label": { "type": "string", "minLength": 1 },
        "archetype": { "$ref": "#/$defs/fund_archetype" },
        "default_restriction_keys": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        }
      }
    }
  }
}
