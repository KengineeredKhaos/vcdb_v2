{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resource capabilities policy",
  "type": "object",
  "required": ["version", "note_max", "classifications"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "note_max": {
      "type": "integer",
      "minimum": 1
    },
    "classifications": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "array",
        "items": {
          "type": "string",
          "minLength": 1
        },
        "minItems": 1,
        "uniqueItems": true
      }
    }
  },
  "additionalProperties": false
}
