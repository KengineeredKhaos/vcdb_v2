{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "properties": {
    "budget": {
      "additionalProperties": false,
      "properties": {
        "periods": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "ends_on": {
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "type": "string"
              },
              "key": {
                "pattern": "^[a-z0-9_]+$",
                "type": "string"
              },
              "label": {
                "type": "string"
              },
              "starts_on": {
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "type": "string"
              }
            },
            "required": [
              "key",
              "label",
              "starts_on",
              "ends_on"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "periods"
      ],
      "type": "object"
    },
    "meta": {
      "additionalProperties": true,
      "properties": {
        "description": {
          "type": "string"
        },
        "effective_on": {
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
          "type": "string"
        },
        "notes": {
          "items": {
            "type": [
              "string",
              "null"
            ]
          },
          "type": "array"
        },
        "policy_key": {
          "pattern": "^[a-z0-9_]+$",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "enum": [
            "draft",
            "active",
            "deprecated"
          ],
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "title",
        "status"
      ],
      "type": "object"
    },
    "spending": {
      "additionalProperties": true,
      "properties": {
        "approvers": {
          "additionalProperties": false,
          "properties": {
            "level1": {
              "items": {
                "pattern": "^[a-z0-9_]+$",
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            },
            "level2": {
              "items": {
                "pattern": "^[a-z0-9_]+$",
                "type": "string"
              },
              "minItems": 1,
              "type": "array"
            }
          },
          "required": [
            "level1",
            "level2"
          ],
          "type": "object"
        },
        "class_caps": {
          "additionalProperties": true,
          "type": "object"
        },
        "staff_cap_cents": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "staff_cap_cents",
        "approvers"
      ],
      "type": "object"
    }
  },
  "required": [
    "meta",
    "budget",
    "spending"
  ],
  "title": "Finance Controls Policy",
  "type": "object"
}
