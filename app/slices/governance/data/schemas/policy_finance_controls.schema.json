{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_finance_controls.schema.json",
  "title": "Finance Controls Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "staff_cap_cents",
    "budget_periods",
    "budget_caps",
    "approval_rules"
  ],
  "properties": {
    "meta": { "$ref": "#/$defs/meta_finance_controls" },
    "staff_cap_cents": {
      "type": "integer",
      "minimum": 0
    },
    "budget_periods": {
      "type": "array",
      "items": { "$ref": "#/$defs/budget_period" }
    },
    "budget_caps": {
      "type": "array",
      "items": { "$ref": "#/$defs/budget_cap" }
    },
    "approval_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval_rule" }
    }
  },
  "$defs": {
    "semantic_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "role_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },
    "op_key": {
      "type": "string",
      "enum": [
        "receive",
        "reserve",
        "encumber",
        "spend",
        "ops_allocate",
        "ops_repay",
        "ops_forgive"
      ]
    },
    "meta_base": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_key": { "type": "string" },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "title": { "type": "string", "minLength": 1 },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "meta_finance_controls": {
      "allOf": [
        { "$ref": "#/$defs/meta_base" },
        {
          "properties": {
            "policy_key": { "const": "finance_controls" }
          }
        }
      ]
    },
    "budget_period": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "period_key",
        "label",
        "start_month",
        "start_day"
      ],
      "properties": {
        "period_key": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "start_month": {
          "type": "integer",
          "minimum": 1,
          "maximum": 12
        },
        "start_day": {
          "type": "integer",
          "minimum": 1,
          "maximum": 31
        }
      }
    },
    "budget_cap": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cap_key",
        "amount_cents"
      ],
      "properties": {
        "cap_key": { "type": "string", "minLength": 1 },
        "fund_code": { "$ref": "#/$defs/semantic_key" },
        "spending_class": { "$ref": "#/$defs/semantic_key" },
        "period_key": { "type": "string", "minLength": 1 },
        "project_tag": { "type": "string", "minLength": 1 },
        "amount_cents": {
          "type": "integer",
          "minimum": 0
        },
        "notes": { "type": "string" }
      }
    },
    "approval_match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "array",
          "items": { "$ref": "#/$defs/op_key" },
          "minItems": 1,
          "uniqueItems": true
        },
        "amount_cents_gt": {
          "type": "integer",
          "minimum": 0
        },
        "selected_fund_codes_any": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },
        "approval_posture_any": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },
        "ops_support_planned": {
          "type": "boolean"
        }
      }
    },
    "approval_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "rule_id",
        "priority",
        "match",
        "required_approvals",
        "reason_code"
      ],
      "properties": {
        "rule_id": {
          "type": "string",
          "pattern": "^[a-z0-9][a-z0-9_-]*$"
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        },
        "match": { "$ref": "#/$defs/approval_match" },
        "required_approvals": {
          "type": "array",
          "items": { "$ref": "#/$defs/role_key" },
          "minItems": 1,
          "uniqueItems": true
        },
        "reason_code": {
          "type": "string",
          "minLength": 1
        }
      }
    }
  }
}
