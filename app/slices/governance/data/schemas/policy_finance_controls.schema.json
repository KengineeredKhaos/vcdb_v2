{
  "$defs": {
    "budget": {
      "additionalProperties": false,
      "properties": {
        "periods": {
          "items": {
            "additionalProperties": false,
            "properties": {
              "lines": {
                "items": {
                  "additionalProperties": false,
                  "properties": {
                    "amount_cents": {
                      "minimum": 0,
                      "type": "integer"
                    },
                    "fund_archetype_key": {
                      "$ref": "#/$defs/token"
                    },
                    "fund_code": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "project_code": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "project_type_key": {
                      "$ref": "#/$defs/token"
                    },
                    "source": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "status": {
                      "$ref": "#/$defs/token"
                    }
                  },
                  "required": [
                    "amount_cents",
                    "fund_archetype_key",
                    "fund_code",
                    "project_code",
                    "project_type_key",
                    "source",
                    "status"
                  ],
                  "type": "object"
                },
                "minItems": 1,
                "type": "array"
              },
              "period_label": {
                "$ref": "#/$defs/singleLine"
              }
            },
            "required": [
              "period_label",
              "lines"
            ],
            "type": "object"
          },
          "minItems": 1,
          "type": "array"
        }
      },
      "required": [
        "periods"
      ],
      "type": "object"
    },
    "cadence": {
      "additionalProperties": false,
      "properties": {
        "label": {
          "$ref": "#/$defs/singleLine"
        },
        "max_per_period": {
          "minimum": 1,
          "type": "integer"
        },
        "period_days": {
          "minimum": 1,
          "type": "integer"
        },
        "scope": {
          "enum": [
            "classification",
            "sku"
          ],
          "type": "string"
        }
      },
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "type": "object"
    },
    "capLeaf": {
      "additionalProperties": false,
      "properties": {
        "cap_cents": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "cap_cents"
      ],
      "type": "object"
    },
    "capNode": {
      "oneOf": [
        {
          "$ref": "#/$defs/capLeaf"
        },
        {
          "additionalProperties": {
            "$ref": "#/$defs/capNode"
          },
          "type": "object"
        }
      ]
    },
    "dateISO": {
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
      "type": "string"
    },
    "meta": {
      "additionalProperties": false,
      "properties": {
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "notes": {
          "default": [],
          "items": {
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$",
            "type": "string"
          },
          "type": "array"
        },
        "policy_key": {
          "const": "finance_controls",
          "type": "string"
        },
        "schema_version": {
          "minimum": 1,
          "type": "integer"
        },
        "status": {
          "$ref": "#/$defs/policyStatus"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "version": {
          "minimum": 1,
          "type": "integer"
        }
      },
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "type": "object"
    },
    "policyStatus": {
      "enum": [
        "draft",
        "active",
        "deprecated"
      ],
      "type": "string"
    },
    "singleLine": {
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$",
      "type": "string"
    },
    "spending": {
      "additionalProperties": false,
      "properties": {
        "approvers": {
          "additionalProperties": {
            "items": {
              "minLength": 1,
              "pattern": "^[^\\n\\r]+$",
              "type": "string"
            },
            "type": "array"
          },
          "minProperties": 1,
          "type": "object"
        },
        "class_caps": {
          "$ref": "#/$defs/capNode"
        },
        "staff_cap_cents": {
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "staff_cap_cents",
        "class_caps",
        "approvers"
      ],
      "type": "object"
    },
    "token": {
      "pattern": "^[a-z][a-z0-9_]{0,63}$",
      "type": "string"
    },
    "tokenUpper2": {
      "pattern": "^[A-Z]{2}$",
      "type": "string"
    },
    "ulid": {
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$",
      "type": "string"
    }
  },
  "$id": "https://vcdb.local/schemas/policy_finance_controls.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Validates policy_finance_controls.json (spending caps/approvers and budget periods).",
  "properties": {
    "budget": {
      "$ref": "#/$defs/budget"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "spending": {
      "$ref": "#/$defs/spending"
    }
  },
  "required": [
    "meta",
    "spending",
    "budget"
  ],
  "title": "Finance Controls Policy Schema",
  "type": "object"
}
