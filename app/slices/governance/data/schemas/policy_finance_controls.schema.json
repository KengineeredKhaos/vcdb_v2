{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.local/schemas/policy_finance_controls.schema.json",
  "title": "Finance Controls Policy Schema",
  "description": "Validates policy_finance_controls.json (spending caps/approvers and budget periods).",
  "type": "object",
  "$defs": {
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "tokenUpper2": {
      "type": "string",
      "pattern": "^[A-Z]{2}$"
    },
    "ulid": {
      "type": "string",
      "pattern": "^[0-9A-HJKMNP-TV-Z]{26}$"
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "$ref": "#/$defs/token"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "cadence": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "scope",
        "period_days",
        "max_per_period"
      ],
      "properties": {
        "scope": {
          "type": "string",
          "enum": [
            "classification",
            "sku"
          ]
        },
        "period_days": {
          "type": "integer",
          "minimum": 1
        },
        "max_per_period": {
          "type": "integer",
          "minimum": 1
        },
        "label": {
          "$ref": "#/$defs/singleLine"
        }
      }
    },
    "capLeaf": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "cap_cents"
      ],
      "properties": {
        "cap_cents": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "capNode": {
      "oneOf": [
        {
          "$ref": "#/$defs/capLeaf"
        },
        {
          "type": "object",
          "additionalProperties": {
            "$ref": "#/$defs/capNode"
          }
        }
      ]
    }
  },
  "additionalProperties": false,
  "required": [
    "meta",
    "spending",
    "budget"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "title",
        "description",
        "version",
        "status",
        "effective_on",
        "schema_version"
      ],
      "properties": {
        "policy_key": {
          "const": "finance_controls"
        },
        "title": {
          "$ref": "#/$defs/singleLine"
        },
        "description": {
          "$ref": "#/$defs/singleLine"
        },
        "notes": {
          "type": "array",
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          },
          "default": []
        },
        "version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": [
            "draft",
            "adopted",
            "deprecated"
          ]
        },
        "effective_on": {
          "$ref": "#/$defs/dateISO"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "spending": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "staff_cap_cents",
        "class_caps",
        "approvers"
      ],
      "properties": {
        "staff_cap_cents": {
          "type": "integer",
          "minimum": 0
        },
        "class_caps": {
          "$ref": "#/$defs/capNode"
        },
        "approvers": {
          "type": "object",
          "minProperties": 1,
          "additionalProperties": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1,
              "pattern": "^[^\\n\\r]+$"
            }
          }
        }
      }
    },
    "budget": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "periods"
      ],
      "properties": {
        "periods": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": [
              "period_label",
              "lines"
            ],
            "properties": {
              "period_label": {
                "$ref": "#/$defs/singleLine"
              },
              "lines": {
                "type": "array",
                "minItems": 1,
                "items": {
                  "type": "object",
                  "additionalProperties": false,
                  "required": [
                    "amount_cents",
                    "fund_archetype_key",
                    "fund_code",
                    "project_code",
                    "project_type_key",
                    "source",
                    "status"
                  ],
                  "properties": {
                    "amount_cents": {
                      "type": "integer",
                      "minimum": 0
                    },
                    "fund_archetype_key": {
                      "$ref": "#/$defs/token"
                    },
                    "fund_code": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "project_code": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "project_type_key": {
                      "$ref": "#/$defs/token"
                    },
                    "source": {
                      "$ref": "#/$defs/singleLine"
                    },
                    "status": {
                      "$ref": "#/$defs/token"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
