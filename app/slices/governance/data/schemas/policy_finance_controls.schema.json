{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_finance_controls.schema.json",
  "title": "Finance Controls Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "staff_cap_cents",
    "approval_rules",
    "budget_periods",
    "budget_caps"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_key": {
          "type": "string",
          "const": "finance_controls"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "title": { "type": "string", "minLength": 1 },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "staff_cap_cents": {
      "type": "integer",
      "minimum": 0
    },
    "approval_rules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "rule_id",
          "priority",
          "match",
          "required_approvals",
          "reason_code"
        ],
        "properties": {
          "rule_id": {
            "type": "string",
            "minLength": 1
          },
          "priority": {
            "type": "integer",
            "minimum": 0
          },
          "match": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "op": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": ["reserve", "encumber", "spend", "receive"]
                },
                "uniqueItems": true
              },
              "amount_cents_gt": {
                "type": "integer",
                "minimum": 0
              },
              "selected_fund_keys_any": {
                "type": "array",
                "items": {
                  "type": "string",
                  "pattern": "^[a-z][a-z0-9_]*$"
                },
                "uniqueItems": true
              }
            }
          },
          "required_approvals": {
            "type": "array",
            "items": { "type": "string" },
            "minItems": 1,
            "uniqueItems": true
          },
          "reason_code": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "budget_periods": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": [
          "period_key",
          "label",
          "start_month",
          "start_day"
        ],
        "properties": {
          "period_key": { "type": "string", "minLength": 1 },
          "label": { "type": "string", "minLength": 1 },
          "start_month": {
            "type": "integer",
            "minimum": 1,
            "maximum": 12
          },
          "start_day": {
            "type": "integer",
            "minimum": 1,
            "maximum": 31
          }
        }
      }
    },
    "budget_caps": {
      "type": "array"
    }
  }
}
