{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_finance_controls.schema.json",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "version",
    "staff_cap_cents",
    "approval_rules",
    "budget_periods",
    "budget_caps"
  ],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "staff_cap_cents": { "type": "integer", "minimum": 0 },

    "approval_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval_rule" }
    },

    "budget_periods": {
      "type": "array",
      "items": { "$ref": "#/$defs/budget_period" }
    },

    "budget_caps": {
      "type": "array",
      "items": { "$ref": "#/$defs/budget_cap" }
    }
  },

  "$defs": {
    "semantic_key": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$"
    },

    "op": {
      "type": "string",
      "enum": ["reserve", "encumber", "spend", "receive"]
    },

    "fund_archetype": {
      "type": "string",
      "enum": [
        "unrestricted",
        "temporarily_restricted",
        "permanently_restricted"
      ]
    },

    "rule_id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9_-]*$"
    },

    "approval_match": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "op": {
          "type": "array",
          "items": { "$ref": "#/$defs/op" },
          "minItems": 1,
          "uniqueItems": true
        },

        "amount_cents_gt": { "type": "integer", "minimum": 0 },
        "amount_cents_gte": { "type": "integer", "minimum": 0 },
        "amount_cents_lte": { "type": "integer", "minimum": 0 },

        "spending_class": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },

        "income_kind": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },

        "expense_kind": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },

        "fund_key_any": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },

        "fund_archetype_any": {
          "type": "array",
          "items": { "$ref": "#/$defs/fund_archetype" },
          "uniqueItems": true
        },

        "restriction_keys_any": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        },

        "restriction_keys_all": {
          "type": "array",
          "items": { "$ref": "#/$defs/semantic_key" },
          "uniqueItems": true
        }
      }
    },

    "approval_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": ["rule_id", "priority", "match"],
      "properties": {
        "rule_id": { "$ref": "#/$defs/rule_id" },
        "priority": { "type": "integer" },
        "match": { "$ref": "#/$defs/approval_match" },

        "required_approvals": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },

        "deny": { "type": "boolean" },

        "reason_code": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        }
      }
    },

    "budget_period": {
      "type": "object",
      "additionalProperties": false,
      "required": ["period_key", "label", "start_month", "start_day"],
      "properties": {
        "period_key": { "$ref": "#/$defs/semantic_key" },
        "label": { "type": "string", "minLength": 1 },
        "start_month": { "type": "integer", "minimum": 1, "maximum": 12 },
        "start_day": { "type": "integer", "minimum": 1, "maximum": 31 }
      }
    },

    "budget_cap": {
      "type": "object",
      "additionalProperties": false,
      "required": ["period_key", "fund_key", "spending_class", "cap_cents"],
      "properties": {
        "period_key": { "$ref": "#/$defs/semantic_key" },
        "fund_key": { "$ref": "#/$defs/semantic_key" },
        "spending_class": { "$ref": "#/$defs/semantic_key" },
        "cap_cents": { "type": "integer", "minimum": 0 }
      }
    }
  }
}
