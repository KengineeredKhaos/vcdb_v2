{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["version", "domain_roles", "assignment_rules"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "domain_roles": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
    "assignment_rules": {
      "type": "object",
      "required": ["rbac_can_assign", "must_include_when_rbac", "forbidden_pairs", "domain_disallows_rbac"],
      "properties": {
        "rbac_can_assign": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "must_include_when_rbac": {
          "type": "object",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "forbidden_pairs": {
          "type": "array",
          "items": { "type": "array", "items": { "type": "string" }, "minItems": 2, "maxItems": 2 }
        },
        "domain_disallows_rbac": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
