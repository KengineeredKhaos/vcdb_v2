{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "vcdb/policy_funding_decisions.schema.json",
  "title": "Funding Decisions Policy",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "approval_thresholds",
    "intent_counting",
    "eligibility_rules",
    "approval_rules",
    "preference_order"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "description",
        "effective_on",
        "notes",
        "policy_key",
        "schema_version",
        "status",
        "title",
        "version"
      ],
      "properties": {
        "description": { "type": "string", "minLength": 1 },
        "effective_on": {
          "type": "string",
          "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
        },
        "notes": {
          "type": "array",
          "items": { "type": "string" }
        },
        "policy_key": {
          "type": "string",
          "const": "funding_decisions"
        },
        "schema_version": {
          "type": "integer",
          "minimum": 1
        },
        "status": {
          "type": "string",
          "enum": ["draft", "active", "deprecated"]
        },
        "title": { "type": "string", "minLength": 1 },
        "version": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "approval_thresholds": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "staff_limit_cents",
        "admin_over_cents"
      ],
      "properties": {
        "staff_limit_cents": {
          "type": "integer",
          "minimum": 0
        },
        "admin_over_cents": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "intent_counting": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "count_statuses",
        "count_intent_kinds"
      ],
      "properties": {
        "count_statuses": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "draft",
              "committed",
              "withdrawn",
              "fulfilled"
            ]
          }
        },
        "count_intent_kinds": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": [
              "pledge",
              "donation",
              "pass_through"
            ]
          }
        }
      }
    },
    "eligibility_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/eligibility_rule" }
    },
    "approval_rules": {
      "type": "array",
      "items": { "$ref": "#/$defs/approval_rule" }
    },
    "preference_order": {
      "type": "array",
      "uniqueItems": true,
      "items": { "$ref": "#/$defs/key_string" }
    }
  },
  "$defs": {
    "key_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "role_string": {
      "type": "string",
      "minLength": 1,
      "maxLength": 64,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "rule_id": {
      "type": "string",
      "minLength": 1,
      "maxLength": 80,
      "pattern": "^[A-Za-z0-9_.:-]+$"
    },
    "eligibility_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "ops",
        "allow_fund_keys",
        "priority"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/rule_id" },
        "enabled": { "type": "boolean" },
        "ops": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["reserve", "encumber", "spend", "receive"]
          }
        },
        "spending_classes_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "income_kinds_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "expense_kinds_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "allow_fund_keys": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "required_tags_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "required_restrictions_all": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "deny_if_restrictions_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "approval_rule": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "enabled",
        "ops",
        "min_amount_cents",
        "required_approvals",
        "selected_fund_keys_any",
        "priority"
      ],
      "properties": {
        "id": { "$ref": "#/$defs/rule_id" },
        "enabled": { "type": "boolean" },
        "ops": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": {
            "type": "string",
            "enum": ["reserve", "encumber", "spend", "receive"]
          }
        },
        "min_amount_cents": {
          "type": "integer",
          "minimum": 0
        },
        "required_approvals": {
          "type": "array",
          "minItems": 1,
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/role_string" }
        },
        "selected_fund_keys_any": {
          "type": "array",
          "uniqueItems": true,
          "items": { "$ref": "#/$defs/key_string" }
        },
        "priority": {
          "type": "integer",
          "minimum": 0
        }
      }
    }
  }
}
