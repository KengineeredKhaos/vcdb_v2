{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Resource lifecycle policy",
  "type": "object",
  "required": ["version", "readiness_status_allowed", "mou_status_allowed"],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "readiness_status_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "mou_status_allowed": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    }
  },
  "additionalProperties": false
}
