{
  "meta": {
    "description": "Fund eligibility and preference rules for reserve, encumber, spend, and receipt flows.",
    "effective_on": "2026-03-16",
    "notes": [
      "Selectors choose eligible/preferred fund keys.",
      "Selectors do not define reporting, reimbursement, or approval obligations."
    ],
    "policy_key": "finance_selectors",
    "schema_version": 1,
    "status": "draft",
    "title": "Finance Selectors",
    "version": 1
  },
  "rules": [
    {
      "rule_id": "sel-100-mission-local-veterans-cash",
      "priority": 100,
      "match": {
        "op": [
          "receive",
          "reserve",
          "encumber",
          "spend"
        ],
        "source_profile_any": [
          "mission_local_veterans_cash"
        ]
      },
      "allow_fund_codes": [
        "general_restricted"
      ],
      "prefer_fund_codes": [
        "general_restricted"
      ]
    },
    {
      "rule_id": "sel-120-welcome-home-reimbursement",
      "priority": 120,
      "match": {
        "op": [
          "receive",
          "reserve",
          "encumber",
          "spend"
        ],
        "source_profile_any": [
          "welcome_home_reimbursement_bridgeable"
        ],
        "spending_class": [
          "basic_needs"
        ],
        "tag_any": [
          "welcome_home_kit"
        ]
      },
      "allow_fund_codes": [
        "welcome_home_reimbursement",
        "general_unrestricted"
      ],
      "prefer_fund_codes": [
        "welcome_home_reimbursement"
      ]
    },
    {
      "rule_id": "sel-140-restricted-project-grant",
      "priority": 140,
      "match": {
        "op": [
          "receive",
          "reserve",
          "encumber",
          "spend"
        ],
        "source_profile_any": [
          "restricted_project_grant_return_unused"
        ]
      },
      "allow_fund_codes": [
        "general_restricted"
      ],
      "prefer_fund_codes": [
        "general_restricted"
      ]
    },
    {
      "rule_id": "sel-160-inkind-offset",
      "priority": 160,
      "match": {
        "op": [
          "receive"
        ],
        "source_profile_any": [
          "inkind_project_offset"
        ]
      },
      "allow_fund_codes": [
        "general_restricted",
        "general_unrestricted"
      ],
      "prefer_fund_codes": [
        "general_restricted"
      ]
    },
    {
      "rule_id": "sel-180-ops-support-defaults",
      "priority": 180,
      "match": {
        "op": [
          "ops_allocate",
          "ops_repay",
          "ops_forgive"
        ],
        "source_kind_any": [
          "operations_support"
        ]
      },
      "allow_fund_codes": [
        "general_unrestricted"
      ],
      "prefer_fund_codes": [
        "general_unrestricted"
      ]
    },
    {
      "rule_id": "sel-900-unrestricted-fallback",
      "priority": 900,
      "match": {
        "op": [
          "receive",
          "reserve",
          "encumber",
          "spend"
        ]
      },
      "allow_fund_codes": [
        "general_unrestricted"
      ],
      "prefer_fund_codes": [
        "general_unrestricted"
      ]
    }
  ]
}
