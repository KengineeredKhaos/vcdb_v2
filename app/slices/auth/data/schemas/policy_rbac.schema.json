{
  "$id": "https://vcdb.local/schemas/policy_rbac.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RBAC Policy Schema",
  "description": "Validates policy_rbac.json (Auth RBAC role definitions).",
  "type": "object",
  "additionalProperties": false,
  "required": ["meta", "rbac_roles"],
  "properties": {
    "meta": { "$ref": "#/$defs/meta" },
    "rbac_roles": { "$ref": "#/$defs/rbac_roles" }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "policy_key",
        "effective_on",
        "description",
        "version",
        "schema_version",
        "title",
        "status"
      ],
      "properties": {
        "policy_key": { "const": "rbac", "type": "string" },
        "schema_version": { "type": "integer", "minimum": 1 },
        "status": { "$ref": "#/$defs/policyStatus" },
        "title": { "$ref": "#/$defs/singleLine" },
        "version": { "type": "integer", "minimum": 1 },
        "effective_on": { "$ref": "#/$defs/dateISO" },
        "description": { "$ref": "#/$defs/singleLine" },
        "notes": {
          "type": "array",
          "default": [],
          "items": {
            "type": "string",
            "maxLength": 70,
            "pattern": "^[^\\n\\r]*$"
          }
        }
      }
    },
    "policyStatus": {
      "type": "string",
      "enum": ["draft", "active", "deprecated"]
    },
    "singleLine": {
      "type": "string",
      "minLength": 1,
      "pattern": "^[^\\n\\r]+$"
    },
    "dateISO": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "token": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]{0,63}$"
    },
    "rbac_role": {
      "type": "object",
      "additionalProperties": false,
      "required": ["code", "label", "summary", "sort_order"],
      "properties": {
        "code": { "$ref": "#/$defs/token" },
        "label": { "$ref": "#/$defs/singleLine" },
        "summary": { "$ref": "#/$defs/singleLine" },
        "sort_order": { "type": "integer", "minimum": 0 }
      }
    },
    "rbac_roles": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/rbac_role" }
    }
  }
}
