{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "VCDB v2 Auth RBAC Policy",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "rbac_roles"],
  "properties": {
    "version": { "type": "integer", "minimum": 1 },
    "rbac_roles": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {
        "type": "string",
        "pattern": "^[a-z][a-z0-9_]{0,31}$"
      }
    }
  }
}
