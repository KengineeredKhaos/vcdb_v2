{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://vcdb.example.org/schemas/sku.schema.json",
  "title": "VCDB SKU",
  "type": "object",
  "required": [
    "sku",
    "category",
    "subcategory",
    "source",
    "size",
    "color",
    "issuance_class"
  ],
  "properties": {
    "sku": {
      "type": "string",
      "description": "Canonical SKU with hyphens for humans: CAT-SUB-SRC-SZ-COL-CND-SEQ",
      "pattern": "^(UW|OW|CW|FW|CG|AC|FD|DG)-(TP|BT|SK|GL|HT|BG|SL|SH|KT)-(DR|LC)-([XSML]|XL|2X|3X|NA|[0-1][0-9][05])-(BK|BL|LB|BR|TN|GN|RD|OR|YL|WT|OD|CY|FG|MC|MX)-([VHDU])-([0-9A-Z]{3})$"
    },
    "category": {
      "type": "string",
      "enum": [
        "UW",
        "OW",
        "CW",
        "FW",
        "CG",
        "AC",
        "FD",
        "DG"
      ]
    },
    "subcategory": {
      "type": "string",
      "enum": [
        "TP",
        "BT",
        "SK",
        "GL",
        "HT",
        "BG",
        "SL",
        "SH",
        "KT"
      ]
    },
    "source": {
      "type": "string",
      "enum": [
        "DR",
        "LC"
      ]
    },
    "size": {
      "type": "string",
      "description": "Apparel alpha sizes; footwear three digits displayed in .5 steps",
      "pattern": "^(XS|S|M|L|XL|2X|3X|NA|[0-1][0-9][05])$"
    },
    "color": {
      "type": "string",
      "enum": [
        "BK",
        "BL",
        "LB",
        "BR",
        "TN",
        "GN",
        "RD",
        "OR",
        "YL",
        "WT",
        "OD",
        "CY",
        "FG",
        "MC",
        "MX"
      ]
    },
    "issuance_class": {
      "type": "string",
      "enum": [
        "V",
        "H",
        "D",
        "U"
      ],
      "description": "V=veteran-only, H=homeless-only, D=durable-return, U=unclassified"
    },
    "seq": {
      "type": "string",
      "pattern": "^[0-9A-Z]{3}$",
      "description": "Base-36 counter per subfamily (000\u2013ZZZ)"
    },
    "title": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "nsn": {
      "type": "string"
    },
    "upc": {
      "type": "string"
    },
    "brand": {
      "type": "string"
    },
    "material": {
      "type": "string"
    },
    "bin_location": {
      "type": "string"
    },
    "qty_on_hand": {
      "type": "integer",
      "minimum": 0
    },
    "default_cost_cents": {
      "type": "integer",
      "minimum": 0
    },
    "price_cents": {
      "type": "integer",
      "minimum": 0
    },
    "active": {
      "type": "boolean",
      "default": true
    },
    "classification_key": {
      "type": "string",
      "description": "Governance policy key used for funding/restriction checks"
    },
    "version": {
      "type": "integer",
      "minimum": 1,
      "default": 1
    }
  },
  "additionalProperties": false,
  "allOf": [
    {
      "if": {
        "properties": {
          "subcategory": {
            "const": "KT"
          }
        }
      },
      "then": {
        "properties": {
          "bundle_components": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "description": "List of component SKUs or notes"
          }
        }
      }
    }
  ]
}
