{ "$schema":"http://json-schema.org/draft-07/schema#",
  "type":"object","required":["batch_ulid","item_ulid","quantity","unit","location_ulid","happened_at_utc"],
  "properties":{
    "batch_ulid":{"type":"string","minLength":26,"maxLength":26},
    "item_ulid":{"type":"string","minLength":26,"maxLength":26},
    "quantity":{"type":"integer","minimum":1},
    "unit":{"type":"string","enum":["each","lbs","kits","boxes","packs"]},
    "location_ulid":{"type":"string","minLength":26,"maxLength":26},
    "happened_at_utc":{"type":"string","format":"date-time"},
    "target_ref_ulid":{"type":"string","minLength":26,"maxLength":26},
    "note":{"type":"string","maxLength":160}
  },
  "additionalProperties":false }
