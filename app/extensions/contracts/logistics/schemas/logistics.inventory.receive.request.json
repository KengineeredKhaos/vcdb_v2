{ "$schema":"http://json-schema.org/draft-07/schema#",
  "type":"object","required":["item_ulid","quantity","unit","source","received_at_utc","location_ulid"],
  "properties":{
    "item_ulid":{"type":"string","minLength":26,"maxLength":26},
    "quantity":{"type":"integer","minimum":1},
    "unit":{"type":"string","enum":["each","lbs","kits","boxes","packs"]},
    "source":{"type":"string","enum":["drmo","donation","purchase","transfer"]},
    "received_at_utc":{"type":"string","format":"date-time"},
    "location_ulid":{"type":"string","minLength":26,"maxLength":26},
    "source_entity_ulid":{"type":"string","minLength":26,"maxLength":26},
    "note":{"type":"string","maxLength":160}
  },
  "additionalProperties":false }
