{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["period_key","metric_code","quantity","unit","source"],
  "properties": {
    "period_key": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "metric_code": { "type": "string", "maxLength": 32 },
    "quantity": { "type": "integer", "minimum": 0 },
    "unit": { "type": "string", "maxLength": 16 },
    "source": { "type": "string", "maxLength": 32 },
    "source_ref_ulid": { "type": "string", "minLength": 26, "maxLength": 26 }
  },
  "additionalProperties": false
}
