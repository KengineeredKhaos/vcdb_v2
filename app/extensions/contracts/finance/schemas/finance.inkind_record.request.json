{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["happened_at_utc","fund_code","amount_cents","valuation_basis"],
  "properties": {
    "happened_at_utc": { "type": "string", "format": "date-time" },
    "fund_code": { "type": "string", "maxLength": 32 },
    "amount_cents": { "type": "integer", "minimum": 1 },
    "valuation_basis": { "type": "string", "maxLength": 32 },
    "expense_acct": { "type": "string", "maxLength": 24 },
    "revenue_acct": { "type": "string", "maxLength": 24 },
    "memo": { "type": "string", "maxLength": 160 },
    "external_ref_ulid": { "type": "string", "minLength": 26, "maxLength": 26 }
  },
  "additionalProperties": false
}
