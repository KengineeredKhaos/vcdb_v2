{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "required": ["period_key","status"],
  "properties": {
    "period_key": { "type": "string", "pattern": "^[0-9]{4}-[0-9]{2}$" },
    "status": { "type": "string", "enum": ["open","soft_closed","closed"] }
  },
  "additionalProperties": false
}
